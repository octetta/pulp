# Fast descending "vocal moan" envelope for pitch glide (roughly linear drop)
( 1 .90 .80 .70 .60 .50 .41 .33 .26 .20 .15 .10 .06 .03 .01 0 )
/d310
# Pitch-envelope modulator (one-shot, silent)
v10 w310,1,1 a0 t 0 0.28 0 0 f 3.57 m1    # ~280 ms total glide duration
# Main "oww" voice – saw wave + resonant lowpass to fake vocal formants
v0 w2 a-3 t 0.012 0.22 0.18 0.08 f 160
    J1 K 1600 Q 2.1                      # resonance peak around ~900–1300 Hz region
    FF1
    F10,280,120                          # sweep: trigger=120+280=400 Hz → rest=120 Hz
    H10,11,-1,-1                         # trigger pitch mod + tiny noise burst
    l1                                   # master trigger point
# Very short breathy/grunt noise transient at onset (optional but adds realism)
v11 w6 a-16 t 0 0.035 0 0 q0
    J2 K 1400 Q 0.9                      # bandpass around mid formant range
