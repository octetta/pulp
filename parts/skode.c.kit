@if(SEQ)
void pattern_show(skode_t *ctx, int pattern_pointer) {
  int first = 1;
  for (int s = 0; s < SEQ_STEPS_MAX; s++) {
    char *line = seq_pattern[pattern_pointer][s];
    if (strlen(line) == 0) break;
    if (first) {
      ctx->printf(ctx, "y%d %%%d # state:%d ptr:%d, len:%d\n",
        pattern_pointer,
        seq_modulo[pattern_pointer],
        seq_state[pattern_pointer],
        seq_pointer[pattern_pointer],
        seq_pattern_length[pattern_pointer]);
      first = 0;
    }
    ctx->printf(ctx, "{%s} x%d", line, s);
    ctx->puts(ctx, "");
  }
}

void tempo_set(float m);
