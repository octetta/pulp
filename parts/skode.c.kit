#include <stdio.h>

#include <stdio.h>
#include <math.h>

/**
 * Prints a connected audio waveform using Braille patterns.
 * This version "connects the dots" by filling the vertical range between samples.
 */
void print_audio_braille_connected(skode_t *ctx, float *data, int n, int width_chars, int height_chars) {
    if (!data || n <= 0 || width_chars <= 0 || height_chars <= 0) return;

    float max_abs = 0.01f;
    for (int i = 0; i < n; i++) {
        float val = fabsf(data[i]);
        if (val > max_abs) max_abs = val;
    }

    int total_dots_y = height_chars * 4;
    int total_dots_x = width_chars * 2;

    const int masks[2][4] = {
        {0x40, 0x04, 0x02, 0x01},
        {0x80, 0x20, 0x10, 0x08}
    };

    // Pre-calculate all Y positions to make connecting easier
    int *y_coords = (int *)malloc(total_dots_x * sizeof(int));
    for (int x = 0; x < total_dots_x; x++) {
        float data_pos = (float)x * (n - 1) / (total_dots_x - 1);
        int idx = (int)data_pos;
        float fract = data_pos - idx;
        
        // Linear interpolation between samples for smoother connections
        float val = data[idx];
        if (idx < n - 1) val = data[idx] * (1.0f - fract) + data[idx+1] * fract;
        
        y_coords[x] = (int)((val / max_abs + 1.0f) * 0.5f * (total_dots_y - 1));
    }

    for (int r = height_chars - 1; r >= 0; r--) {
        for (int c = 0; c < width_chars; c++) {
            int pattern = 0;

            for (int dx = 0; dx < 2; dx++) {
                int x = c * 2 + dx;
                int y_curr = y_coords[x];
                // Connect to previous dot (or same dot if at start)
                int y_prev = (x > 0) ? y_coords[x-1] : y_curr;

                int y_min = (y_curr < y_prev) ? y_curr : y_prev;
                int y_max = (y_curr > y_prev) ? y_curr : y_prev;

                // Fill all dots between y_min and y_max that fall in this character row
                for (int y = y_min; y <= y_max; y++) {
                    if (y / 4 == r) {
                        pattern |= masks[dx][y % 4];
                    }
                }
            }
            ctx->printf(ctx, "%c%c%c", 0xE2, 0xA0 | (pattern >> 6), 0x80 | (pattern & 0x3F));
        }
        ctx->printf(ctx, "\n");
    }
    free(y_coords);
}

#include <stdio.h>
#include <stdlib.h>
#include <math.h>

void print_audio_braille_labeled(skode_t *ctx, float *data, int n, int width_chars, int height_chars, int offset, int trim) {
    if (!data || n <= 0 || width_chars <= 0 || height_chars <= 0) return;

    float max_abs = 0.01f;
    for (int i = 0; i < n; i++) {
        float val = fabsf(data[i]);
        if (val > max_abs) max_abs = val;
    }

    int total_dots_y = height_chars * 4;
    int total_dots_x = width_chars * 2;

    const int masks[2][4] = {
        {0x40, 0x04, 0x02, 0x01},
        {0x80, 0x20, 0x10, 0x08}
    };

    // Pre-calculate Y positions
    int *y_coords = (int *)malloc(total_dots_x * sizeof(int));
    for (int x = 0; x < total_dots_x; x++) {
        float data_pos = (float)x * (n - 1) / (total_dots_x - 1);
        int idx = (int)data_pos;
        float fract = data_pos - idx;
        
        float val = data[idx];
        if (idx < n - 1) val = data[idx] * (1.0f - fract) + data[idx+1] * fract;
        
        y_coords[x] = (int)((val / max_abs + 1.0f) * 0.5f * (total_dots_y - 1));
    }

    // 1. Draw the Waveform rows
    for (int r = height_chars - 1; r >= 0; r--) {
        ctx->printf(ctx, ":");
        for (int c = 0; c < width_chars; c++) {
            int pattern = 0;
            for (int dx = 0; dx < 2; dx++) {
                int x = c * 2 + dx;
                int y_curr = y_coords[x];
                int y_prev = (x > 0) ? y_coords[x-1] : y_curr;
                int y_min = (y_curr < y_prev) ? y_curr : y_prev;
                int y_max = (y_curr > y_prev) ? y_curr : y_prev;

                for (int y = y_min; y <= y_max; y++) {
                    if (y / 4 == r) pattern |= masks[dx][y % 4];
                }
            }
            ctx->printf(ctx, "%c%c%c", 0xE2, 0xA0 | (pattern >> 6), 0x80 | (pattern & 0x3F));
        }
        ctx->printf(ctx, ":\n");
    }

    // 2. Draw the Marker row (Offset and Trim)
    // Map indices to dot positions
    int dot_offset = (int)((float)offset * (total_dots_x - 1) / (n - 1));
    int dot_trim   = (int)((float)trim   * (total_dots_x - 1) / (n - 1));

    ctx->printf(ctx, "^");
    for (int c = 0; c < width_chars; c++) {
        int pattern = 0;
        for (int dx = 0; dx < 2; dx++) {
            int x = c * 2 + dx;
            // Use Dot 1 (0x01) and Dot 4 (0x08) as markers on the top of the char
            if (x >= dot_offset && x <= dot_trim) {
                pattern |= (dx == 0) ? 0x01 : 0x08;
            }
        }
        ctx->printf(ctx, "%c%c%c", 0xE2, 0xA0 | (pattern >> 6), 0x80 | (pattern & 0x3F));
    }
    ctx->printf(ctx, "^\n");

    free(y_coords);
}

int wavetable_show(skode_t *ctx, int n) {
  if (n >= 0 && n < WAVE_TABLE_MAX && sw.data[n] && sw.size[n]) {
    int readonly = sw.readonly[n];
    int refcount = sw.refcount[n];
    int size = sw.size[n];
    ctx->printf(ctx, "# w%d size:%d", n, size);
    ctx->printf(ctx, " rate:%g +hz:%g midi:%g",
      sw.rate[n],
      sw.offset_hz[n],
      sw.midi_note[n]);
    if (readonly) {
      ctx->printf(ctx, " r/o ref:%d", refcount);
    } else {
      ctx->printf(ctx, " r/w ref:%d", refcount);
    }
    ctx->printf(ctx, " '%s'", sw.name[n]);
    ctx->puts(ctx, "");
    @if(SCOPE)
    if (scope_enable) {
      downsample_block_average_min_max(table, size, scope->wave_data, SCOPE_WAVE_WIDTH, scope->wave_min, scope->wave_max);
      scope->wave_len = SCOPE_WAVE_WIDTH;
    }
    @endif
  }
  return 0;
}

void wave_table_dynamic_expand(int n) {
  float fbig = 0.0;
  float fsmall = 0.0;
  int len = sw.size[n];
  float *samples = sw.data[n];
  if (len <= 0 || samples == NULL) {
    return;
  }
  for (int i = 0; i < len; i++) {
    float g = samples[i];
    if (g > fbig) fbig = g;
    if (g < fsmall) fsmall = g;
  }

  // use the min/max to make a scale factor that keeps 0
  // in the same relative place

  float scale;
  if (fabsf(fsmall) > fabsf(fbig)) {
    scale = -1.0f / fsmall;
  } else {
    scale = 1.0f / fbig;
  }

  // Convert scaled float samples to 16-bit PCM

  for (int i = 0; i < len; i++) {
    float g = samples[i];
    g *= scale;
    if (g > 1.0f) g = 1.0f;
    if (g < -1.0f) g = -1.0f;
    samples[i] = g;
  }
}

#include <sys/time.h>
#include <unistd.h>

void skode_sample(int how_many) {
  if (sampling.busy) {
    return;
  }
  if (sampling.capacity < how_many) {
    if (sampling.where) {
      free(sampling.where);
      sampling.where = NULL;
    }
    if (sampling.where == NULL) {
      sampling.capacity = how_many;
      sampling.where = (float *)calloc(how_many + 4096, sizeof(float));
      for (int i=0; i<how_many; i++) sampling.where[i] = 0.0;
    }
    sampling.how_many = how_many;
    sampling.go = 1;
  } else {
    sampling.how_many = how_many;
    sampling.go = 1;
  }
}

