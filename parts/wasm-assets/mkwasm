#!/bin/bash

# put a few goodies in the wasm
cp ../sk/909.sk ../sk-out     # from skred
cp ../sk/124.sk ../sk-out     # from skred
cp ../sk/drums-*.ks ../sk-out # from k-synth
cp ../wav/24.mp3 ../wav-out   # thanks BBC

emcc -I. -I.. \
    -pthread \
    --embed-file ../sk-out@/sk \
    --embed-file ../wav-out@/wav \
    ../ands.c \
    ../miniaudio.c \
    ../util.c \
    ../miniwav.c \
    ../skqueue.c \
    seq.c \
    api.c \
    synth.c \
    skode.c \
    synth-alloc.c \
    ../kse.c \
    ../ksynth.c \
    ../ks_chan.c \
    -o skred_api.js \
    -s EXPORTED_FUNCTIONS='["_skred_start", "_skred_command", "_skred_stop", "_skred_features", "_skred_log", "_skred_logger", "_skred_devices", "_skred_device_idx", "_skred_device_str", "_skred_enumerate_devices", "_skred_set_audio_device", "_skred_audio_refresh", "_skred_audio_select", "_skred_audio_reconnect", "_skred_audio_disconnect", "_skred_audio_running", "_skred_audio_status", "_skred_audio_command", "_skred_audio_message" ]' \
    -s EXPORTED_RUNTIME_METHODS='["ccall", "cwrap", "FS", "UTF8ToString", "stringToUTF8" ]' \
    -s FORCE_FILESYSTEM=1 \
    -s ALLOW_MEMORY_GROWTH=1 \
    -s MAXIMUM_MEMORY=4GB \
    -s INITIAL_MEMORY=64MB \
    -s MALLOC='emmalloc' \
    -Oz
